# Copy to .env and fill in after account signups (all free tiers).
# EXPO_PUBLIC_* values are inlined into the client bundle at build time.

# --- required ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# --- required for the Android map (react-native-maps / Google Maps SDK) ---
# Read by app.config.ts and injected into the native build. Without it the map
# tab renders blank on Android. Store it as an EAS secret for real builds.
GOOGLE_MAPS_API_KEY=

# --- optional: observability (no-ops when unset, so dev/Expo Go stay quiet) ---
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=
