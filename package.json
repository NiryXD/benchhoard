{
  "name": "benchhoard",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm run start --workspace apps/mobile",
    "android": "npm run android --workspace apps/mobile",
    "web": "npm run dev --workspace web",
    "web:build": "npm run build --workspace web",
    "seed:benches": "node supabase/seed/benches-osm.mjs",
    "test:shared": "npm run test --workspace packages/shared"
  }
}
